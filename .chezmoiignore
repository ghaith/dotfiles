# nixos config — managed separately, not deployed as dotfiles
nixos
nixos/**

# pi - machine-local state and secrets
.pi/agent/auth.json
.pi/agent/usage.json
.pi/agent/sessions
.pi/agent/sessions/**

# Theme state (machine-local, managed by theme-switch)
.config/theme

# pi - generated by npm install inside extensions
.pi/agent/extensions/**/node_modules
.pi/agent/extensions/**/node_modules/**

# tmux plugins (cloned by run_after script, not managed by chezmoi)
.config/tmux/plugins
.config/tmux/plugins/**

# Desktop-only configs — skip on servers and devcontainers
{{ if and (hasKey . "type") (ne .type "desktop") }}
.config/niri
.config/niri/**
.config/sway
.config/sway/**
.config/waybar
.config/waybar/**
.config/alacritty
.config/alacritty/**
.config/kitty
.config/kitty/**
.config/ghostty
.config/ghostty/**
.config/wezterm
.config/wezterm/**
.config/DankMaterialShell
.config/DankMaterialShell/**
.config/xdg-desktop-portal
.config/xdg-desktop-portal/**
.config/systemd/user/swayidle.service
.config/systemd/user/swaybg.service
.config/systemd/user/swaybg.timer
.local/scripts/changebg.sh
.local/scripts/lock.sh
.local/scripts/random_wallpaper.sh
{{ end }}
